# === Variables d'environnement Phase Test Frontend (Local + GCP) ===
# Mode LOCAL: utiliser Dockerfile.dev (hot reload, volumes)
# Mode GCP: FRONT_DOCKERFILE=Dockerfile (build production)

# Commutateurs Mode (LOCAL / GCP)
FRONT_DOCKERFILE=Dockerfile.dev
NODE_ENV=test

# === API Proxy (communication interne au réseau Docker) ===
# LOCAL: http://localhost:3006 (backend sur port 3006)
# GCP: http://api-test:3000 (réseau docker interne, voir docker-compose.test.yml du backend)
API_PROXY_TARGET=http://localhost:3006
NEXT_PUBLIC_API_URL=http://localhost:3006

# === Google Maps (optionnel pour tests) ===
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
